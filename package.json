{
  "name": "@tyroneross/navgator",
  "version": "0.9.1",
  "description": "Architecture connection tracker for Claude Code and Codex - know your stack before you change it",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "navgator": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scanner": {
      "types": "./dist/scanner.d.ts",
      "import": "./dist/scanner.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.js"
    }
  },
  "files": [
    "dist",
    "web/server.cjs",
    "web/runtime",
    "skills",
    "hooks",
    "commands",
    "agents",
    ".claude-plugin",
    ".codex-plugin",
    ".mcp.json",
    "scripts/install-plugin.sh",
    "scripts/install-codex-plugin.sh",
    "scripts/promote-lessons.py",
    "CLAUDE.md",
    "README.md",
    "AGENTS.md",
    "VERSIONING.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "npm run build:cli && npm run build:web",
    "build:cli": "tsc && npm run build:fixshebang",
    "build:fixshebang": "node -e \"const fs=require('fs');const f='dist/cli/index.js';let c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!')){c='#!/usr/bin/env node\\n'+c;fs.writeFileSync(f,c);}\"",
    "build:web": "npm --prefix web run build && npm run build:standalone",
    "build:standalone": "node scripts/prepare-web-runtime.mjs",
    "dev": "tsc --watch",
    "dev:web": "cd web && next dev",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:release": "npm test",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json && tsc -p web/tsconfig.json --noEmit",
    "verify:release": "node scripts/verify-release.mjs",
    "clean": "rm -rf dist web/.next web/runtime web/server.js web/server.cjs",
    "prepublishOnly": "npm run clean && npm run build && npm run verify:release",
    "link:local": "npm run build && npm link",
    "install:claude": "bash scripts/install-plugin.sh --global",
    "install:codex": "bash scripts/install-codex-plugin.sh --user",
    "install:codex-workspace": "bash scripts/install-codex-plugin.sh --workspace",
    "install-plugin": "bash scripts/install-plugin.sh --global",
    "mcp": "node dist/mcp/server.js"
  },
  "keywords": [
    "claude-code",
    "codex",
    "architecture",
    "dependencies",
    "devtools",
    "cli",
    "connections",
    "impact-analysis"
  ],
  "author": "Tyrone Ross",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyroneross/NavGator.git"
  },
  "homepage": "https://github.com/tyroneross/NavGator#readme",
  "bugs": {
    "url": "https://github.com/tyroneross/NavGator/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "glob": "^13.0.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.4.0",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@sourcegraph/scip-typescript": "^0.4.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
